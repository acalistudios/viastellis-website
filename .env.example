# ViaStellis Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Supabase (get from: Project Settings → API) ──────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App config ────────────────────────────────────────────────
VITE_APP_ENV=development

# ── Supabase Edge Functions secrets (set via Supabase Dashboard) ──
# These are NOT prefixed with VITE_ — they live server-side only.
# Set them at: Project Settings → Edge Functions → Secrets
# GEMINI_API_KEY=your-gemini-api-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (auto-available in edge functions)
